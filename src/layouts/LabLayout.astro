---
import '../styles/lab/lab.css';
import LabControls from '../components/lab/LabControls.astro';
import LabNavigation from '../components/lab/LabNavigation.astro';
import { getLabBreadcrumbs, normalizeLabPath } from '../data/lab/catalog';

interface Props {
	title: string;
	description: string;
	breadcrumbLabel?: string;
}

const { title, description, breadcrumbLabel } = Astro.props;
const currentPath = normalizeLabPath(Astro.url.pathname);
const breadcrumbs = getLabBreadcrumbs(currentPath, breadcrumbLabel);
---

<!doctype html>
<html lang="zh-Hant" data-motion="full" data-motion-setting="system" data-sound="off" data-performance="standard" data-performance-setting="auto">
	<head>
		<meta charset="UTF-8" />
		<meta name="viewport" content="width=device-width, initial-scale=1" />
		<meta name="description" content={description} />
		<meta name="robots" content="noindex, nofollow, noarchive" />
		<meta name="theme-color" content="#08131f" />
		<meta name="generator" content={Astro.generator} />
		<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
		<link rel="icon" href="/favicon.ico" />
		<title>{title}</title>
	</head>
	<body>
		<a class="lab-skip-link" href="#lab-main">跳至主要內容</a>
		<LabNavigation currentPath={currentPath} />
		{breadcrumbs.length > 0 && (
			<nav class="lab-breadcrumb" aria-label="麵包屑">
				<ol>
					{breadcrumbs.map((item) => (
						<li>{item.href ? <a href={item.href}>{item.label}</a> : <span aria-current="page">{item.label}</span>}</li>
					))}
				</ol>
			</nav>
		)}
		<LabControls />

		<main id="lab-main">
			<slot />
		</main>

		<footer class="lab-footer">
			<p>厄倫蒂兒好氣質・功能實驗室</p>
			<p>Prototype only · Noindex</p>
		</footer>
	</body>
</html>
