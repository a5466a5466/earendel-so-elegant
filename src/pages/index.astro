---
import BaseLayout from '../layouts/BaseLayout.astro';

const projects = [
	{ no: '01', date: '2026 · SUMMER', title: '星光花園', en: 'Garden of Starlight', copy: '以她歌聲裡的溫柔為種子，把來自不同地方的祝福，種成一座只在夜裡盛開的花園。', tone: 'blue' },
	{ no: '02', date: '2026 · BIRTHDAY', title: '遠星來信', en: 'Letters to Earendel', copy: '一封信，一句想說很久的話。收集細小而真摯的心意，寄往那顆照亮我們的星。', tone: 'gold' },
	{ no: '03', date: '2025 · ARCHIVE', title: '月色音樂會', en: 'Concert Under Moonlight', copy: '收藏那些被歌聲接住的夜晚，也收藏我們曾經一起仰望、一起靜靜聆聽的時刻。', tone: 'rose' },
];

const labUrl = `${import.meta.env.BASE_URL.replace(/\/$/, '')}/lab/`;
---

<BaseLayout title="厄倫蒂兒好氣質｜Earendel, So Elegant" description="獻給厄倫蒂兒的非官方粉絲應援網站。收藏她的優雅、歌聲，與我們一起走過的星光。">
	<input class="home-intro-toggle" id="home-intro-toggle" type="checkbox" aria-label="略過首頁入場動畫" />
	<div class="home-intro" data-home-intro aria-label="厄倫蒂兒首頁入場動畫">
		<div class="home-intro-stars" aria-hidden="true"></div>
		<div class="home-intro-mark" aria-hidden="true">
			<svg viewBox="0 0 120 120"><path d="M60 4 68 52l48 8-48 8-8 48-8-48-48-8 48-8 8-48Z"/><circle cx="60" cy="60" r="8"/></svg>
		</div>
		<div class="home-intro-title">
			<p>For the star who sings beyond the night</p>
			<h1><span>厄倫蒂兒</span><em>好氣質，從星光開始</em></h1>
		</div>
		<label for="home-intro-toggle">略過動畫</label>
	</div>

	<header class="site-header" data-header>
		<a class="brand" href="#top" aria-label="回到首頁">
			<svg viewBox="0 0 48 48" aria-hidden="true"><path d="M24 2 28.4 19.6 46 24l-17.6 4.4L24 46l-4.4-17.6L2 24l17.6-4.4L24 2Z"/><circle cx="24" cy="24" r="4.4"/></svg>
			<span><b>厄倫蒂兒</b><small>SO ELEGANT</small></span>
		</a>
		<button class="menu-toggle" type="button" aria-expanded="false" aria-controls="site-nav"><span></span><span></span><span class="sr-only">開啟選單</span></button>
		<nav id="site-nav" class="site-nav" aria-label="主要導覽">
			<a href="#about">關於她</a><a href="#projects">應援企劃</a><a href="#moments">星光片刻</a><a href="#follow">追隨星光</a><a href={labUrl}>功能實驗室</a>
		</nav>
		<noscript><style>@media (max-width:720px){.menu-toggle{display:none}.site-nav{visibility:visible;transform:none;opacity:1}}</style></noscript>
	</header>

	<main id="main">
		<section id="top" class="hero">
			<div class="hero-stars" aria-hidden="true"></div>
			<div class="hero-orbit orbit-one" aria-hidden="true"></div><div class="hero-orbit orbit-two" aria-hidden="true"></div>
			<div class="hero-celestials" aria-hidden="true">
				<i class="hero-celestial celestial-star celestial-star-one"></i>
				<i class="hero-celestial celestial-orb celestial-orb-one"></i>
				<i class="hero-celestial celestial-moon"></i>
				<i class="hero-celestial celestial-ring"></i>
				<i class="hero-celestial celestial-star celestial-star-two"></i>
				<i class="hero-celestial celestial-orb celestial-orb-two"></i>
			</div>
			<div class="hero-content">
				<p class="hero-kicker">For the star who sings beyond the night</p>
				<h1><span>厄倫蒂兒</span><em>好氣質</em></h1>
				<p class="hero-intro">她從很遠的地方來，<br />卻讓每一個夜晚，都有了溫柔的名字。</p>
				<a class="hero-cta" href="#about"><span>循著星光</span><i aria-hidden="true">↓</i></a>
			</div>
			<div class="hero-figure" aria-hidden="true">
				<div class="halo"></div><div class="moon"></div>
				<svg viewBox="0 0 600 820" role="presentation">
					<defs><linearGradient id="dress" x1="0" y1="0" x2="1" y2="1"><stop stop-color="#d7e0e3"/><stop offset=".55" stop-color="#8fa8b5"/><stop offset="1" stop-color="#455e70"/></linearGradient><linearGradient id="hair" x1="0" y1="0" x2="1" y2="1"><stop stop-color="#f1e4c7"/><stop offset="1" stop-color="#ae9365"/></linearGradient></defs>
					<path fill="url(#hair)" d="M316 112c-68 2-111 62-107 139 4 87-26 151-69 210 52-19 91-53 113-99-3 83-33 146-72 193 77-28 134-92 152-170 13 76 50 128 107 161-38-62-56-128-49-199 8-82-7-163-75-211Z" opacity=".95"/>
					<ellipse cx="310" cy="222" rx="69" ry="87" fill="#e5c5a8"/><path fill="#f4ead8" d="M248 208c23-27 44-65 56-97 60 25 86 65 77 123-27-12-49-35-63-66-17 30-41 47-70 40Z"/>
					<path fill="url(#dress)" d="M215 377c55-44 132-48 190 1l39 107c53 123 91 220 114 322H60c25-107 68-218 119-326l36-104Z"/>
					<path fill="#e8eef0" d="m212 381-57 129 48 18 42-105 63 61 68-61 42 105 49-18-60-132c-23 30-59 54-100 78-39-26-70-51-95-75Z" opacity=".85"/>
					<path d="M308 455v352M189 544c80 37 155 37 237 0" fill="none" stroke="#c8b47c" stroke-width="4" opacity=".75"/>
					<path d="m307 470 11 21 23 4-17 16 4 24-21-11-21 11 4-24-18-16 24-4 11-21Z" fill="#dac58c"/>
				</svg>
			</div>
			<p class="hero-side-note">UNOFFICIAL FAN PROJECT<br />EST. 2026 · TAIWAN</p>
		</section>

		<section id="about" class="about section">
			<div class="container about-grid">
				<div class="about-art" data-reveal>
					<div class="arch"><div class="constellation"><i></i><i></i><i></i><i></i><i></i></div><span>Ἑωσφόρος</span></div>
					<p>“ 在最深的夜裡，<br />也做最溫柔的光。 ”</p>
				</div>
				<div class="about-copy" data-reveal>
					<p class="eyebrow">About Earendel</p>
					<h2 class="section-title">像黎明前，<br />最安靜的那顆星。</h2>
					<div class="ornament">✦</div>
					<p class="section-copy">優雅從來不只是姿態。是她唱歌時，將每一個字都輕輕捧著；是面對世界時，依然保有自己的節奏與溫度。</p>
					<p class="section-copy">我們喜歡的厄倫蒂兒，有時像月光，有時像遠方的風。她不張揚，卻總能在不經意的瞬間，照亮某一個人的夜晚。</p>
					<dl class="about-facts"><div><dt>NAME</dt><dd>Earendel</dd></div><div><dt>SYMBOL</dt><dd>Morning Star</dd></div><div><dt>ESSENCE</dt><dd>Grace & Light</dd></div></dl>
				</div>
			</div>
		</section>

		<section id="projects" class="projects section">
			<div class="container">
				<div class="section-heading" data-reveal><div><p class="eyebrow">Fan Projects</p><h2 class="section-title">把喜歡，做成有形的光。</h2></div><p class="section-copy">每一次應援，都是我們與她之間<br />安靜而認真的約定。</p></div>
				<div class="project-list">
					{projects.map((project) => <article class={`project-card ${project.tone}`} data-reveal>
						<div class="project-visual" aria-hidden="true"><span class="project-no">{project.no}</span><div class="project-celestial"><i></i></div></div>
						<div class="project-info"><p>{project.date}</p><h3>{project.title}</h3><span>{project.en}</span><p class="project-copy">{project.copy}</p><a href="#follow" aria-label={`閱讀${project.title}企劃`}>閱讀企劃 <b>↗</b></a></div>
					</article>)}
				</div>
			</div>
		</section>

		<section id="moments" class="moments section">
			<div class="moments-glow" aria-hidden="true"></div>
			<div class="container moments-inner" data-reveal>
				<p class="eyebrow">A Gentle Reminder</p>
				<blockquote>「願你走過漫長的夜，<br />依然相信星星會亮。」</blockquote>
				<div class="wave" aria-hidden="true">— ︿ — ﹀ — ︿ — ﹀ —</div>
				<p>收藏一句話，也收藏被她溫柔接住的那個自己。</p>
			</div>
		</section>

		<section id="follow" class="follow section">
			<div class="container follow-grid">
				<div data-reveal><p class="eyebrow">Follow the Starlight</p><h2 class="section-title">星光未完，<br />我們也還在路上。</h2></div>
				<div class="follow-copy" data-reveal><p class="section-copy">這是一個由喜歡開始，也會因喜歡繼續生長的地方。歡迎你帶著自己的故事，和我們一起收藏往後的每一束光。</p><div class="socials"><a href="#" aria-label="YouTube">YT <span>↗</span></a><a href="#" aria-label="X / Twitter">X <span>↗</span></a><a href="#" aria-label="Threads">TH <span>↗</span></a></div></div>
				<div class="follow-star" aria-hidden="true"><svg viewBox="0 0 200 200"><path d="M100 2c4 61 37 94 98 98-61 4-94 37-98 98-4-61-37-94-98-98 61-4 94-37 98-98Z"/><circle cx="100" cy="100" r="16"/></svg></div>
			</div>
		</section>
	</main>

	<footer><div class="container"><div class="footer-brand">✦ <span>EAR<span>EN</span>DEL</span></div><p>非官方粉絲應援網站 · UNOFFICIAL FAN PROJECT</p><p>Made with grace & starlight.</p></div></footer>

	<script>
		const header = document.querySelector('[data-header]');
		const toggle = document.querySelector<HTMLButtonElement>('.menu-toggle');
		const nav = document.querySelector('.site-nav');
		const onScroll = () => header?.classList.toggle('is-scrolled', window.scrollY > 30);
		onScroll(); window.addEventListener('scroll', onScroll, { passive: true });
		const closeMenu = () => { toggle?.setAttribute('aria-expanded', 'false'); nav?.classList.remove('is-open'); };
		toggle?.addEventListener('click', () => { const open = toggle.getAttribute('aria-expanded') === 'true'; toggle.setAttribute('aria-expanded', String(!open)); nav?.classList.toggle('is-open', !open); });
		nav?.querySelectorAll('a').forEach((link) => link.addEventListener('click', () => { toggle?.setAttribute('aria-expanded', 'false'); nav.classList.remove('is-open'); }));
		document.addEventListener('keydown', (event) => { if (event.key === 'Escape' && toggle?.getAttribute('aria-expanded') === 'true') { closeMenu(); toggle.focus(); } });
		const items = document.querySelectorAll('[data-reveal]');
		if ('IntersectionObserver' in window && !matchMedia('(prefers-reduced-motion: reduce)').matches) {
			const observer = new IntersectionObserver((entries) => entries.forEach((entry) => { if (entry.isIntersecting) { entry.target.classList.add('is-visible'); observer.unobserve(entry.target); } }), { threshold: .14 });
			items.forEach((item) => observer.observe(item));
		} else { items.forEach((item) => item.classList.add('is-visible')); }
	</script>
</BaseLayout>

<style>
	.home-intro-toggle { position: fixed; z-index: 1001; right: 24px; bottom: 24px; width: 1px; height: 1px; opacity: 0; }
	.home-intro { position: fixed; z-index: 1000; inset: 0; display: grid; overflow: hidden; place-items: center; background: #06101c; color: #f4f1e9; isolation: isolate; animation: intro-overlay-out .5s 2.8s ease forwards; }
	.home-intro-toggle:checked + .home-intro { visibility: hidden; opacity: 0; pointer-events: none; animation: none; }
	main { --hero-entry-delay: 3.15s; }
	.home-intro-toggle:checked ~ main { --hero-entry-delay: .08s; }
	.home-intro::before { content: ''; position: absolute; width: min(78vw, 820px); aspect-ratio: 1; border: 1px solid rgba(222, 208, 168, .14); border-radius: 50%; opacity: 0; animation: intro-orbit 1.7s .2s ease-out forwards; }
	.home-intro-stars { position: absolute; inset: 0; opacity: 0; background-image: radial-gradient(circle, #fff 0 1px, transparent 1.5px), radial-gradient(circle, #d9c99d 0 1px, transparent 1.5px); background-position: 0 0, 47px 63px; background-size: 113px 107px, 151px 139px; animation: intro-stars 1.2s .15s ease-out forwards; }
	.home-intro-mark { position: absolute; width: clamp(58px, 7vw, 88px); color: var(--gold-light); opacity: 0; transform: scale(.45) rotate(-22deg); animation: intro-mark 1s .2s cubic-bezier(.2,.75,.2,1) forwards, intro-mark-out .45s 2.15s ease-in forwards; }
	.home-intro-mark svg { fill: none; stroke: currentColor; stroke-width: 1.2; filter: drop-shadow(0 0 18px rgba(222,208,168,.48)); }
	.home-intro-title { position: relative; z-index: 2; width: min(88vw, 900px); text-align: center; opacity: 0; transform: translateY(24px); animation: intro-title-in .75s .88s cubic-bezier(.2,.75,.2,1) forwards, intro-title-out .5s 2.15s ease-in forwards; }
	.home-intro-title p { margin: 0 0 1.4rem; color: var(--gold-light); font: 400 .64rem var(--sans); letter-spacing: .32em; text-transform: uppercase; }
	.home-intro-title h1 { display: grid; gap: 1rem; margin: 0; font-weight: 400; }
	.home-intro-title h1 span { font-size: clamp(3.2rem, 9vw, 7.5rem); letter-spacing: .16em; line-height: 1; }
	.home-intro-title h1 em { color: var(--gold-light); font-size: clamp(.9rem, 2vw, 1.35rem); font-style: normal; letter-spacing: .38em; }
	.home-intro label { position: absolute; z-index: 3; right: max(22px, env(safe-area-inset-right)); bottom: max(22px, env(safe-area-inset-bottom)); padding: .65rem .9rem; border: 1px solid rgba(222,208,168,.4); border-radius: 999px; background: rgba(6,16,28,.65); color: rgba(244,241,233,.72); font: 400 .65rem var(--sans); letter-spacing: .14em; cursor: pointer; opacity: 0; animation: intro-skip .4s .6s ease-out forwards; }
	.home-intro label:hover, .home-intro-toggle:focus-visible + .home-intro label { border-color: var(--gold-light); color: #fff; outline: 2px solid rgba(222,208,168,.45); outline-offset: 3px; }
	@keyframes intro-overlay-out { to { visibility: hidden; opacity: 0; pointer-events: none; } }
	@keyframes intro-stars { to { opacity: .34; } }
	@keyframes intro-orbit { from { opacity: 0; transform: scale(.72) rotate(-16deg); } to { opacity: 1; transform: scale(1) rotate(-16deg); } }
	@keyframes intro-mark { to { opacity: 1; transform: scale(1) rotate(0); } }
	@keyframes intro-mark-out { to { opacity: 0; transform: scale(1.18); } }
	@keyframes intro-title-in { to { opacity: 1; transform: none; } }
	@keyframes intro-title-out { to { opacity: 0; transform: translateY(-18px); } }
	@keyframes intro-skip { to { opacity: 1; } }
	@keyframes hero-copy-in { from { opacity: 0; transform: translateY(16px); filter: blur(5px); } to { opacity: 1; transform: none; filter: blur(0); } }
	@keyframes hero-title-in { from { opacity: 0; transform: translateY(28px) scale(.985); letter-spacing: .16em; filter: blur(7px); } to { opacity: 1; transform: none; filter: blur(0); } }
	@keyframes hero-figure-in { from { opacity: 0; transform: translateY(30px) scale(.985); filter: blur(8px); } to { opacity: 1; transform: none; filter: blur(0); } }
	@keyframes hero-figure-breathe { 0%, 100% { transform: none; } 50% { transform: translateY(-20px) scale(1.014); } }
	@keyframes celestial-enter { from { opacity: 0; transform: translateY(24px) scale(.3) rotate(-18deg); filter: blur(7px); } to { opacity: var(--celestial-opacity, .8); transform: none; filter: blur(0); } }
	@keyframes celestial-float { 0%, 100% { transform: translate3d(0,0,0) rotate(var(--celestial-tilt, 0deg)); } 50% { transform: translate3d(var(--celestial-drift-x, 4px),var(--celestial-drift-y, -12px),0) rotate(var(--celestial-tilt, 0deg)); } }

	.sr-only { position:absolute; width:1px; height:1px; overflow:hidden; clip:rect(0,0,0,0); }
	.site-header { position: fixed; z-index: 50; inset: 0 0 auto; display:flex; align-items:center; justify-content:space-between; height:92px; padding:0 4vw; color:#f4f1e9; transition:.35s ease; }
	.site-header.is-scrolled { height:72px; background:rgba(8,19,31,.86); backdrop-filter:blur(14px); border-bottom:1px solid rgba(255,255,255,.08); }
	.brand { display:flex; align-items:center; gap:.75rem; text-decoration:none; }
	.brand svg { width:31px; fill:none; stroke:var(--gold-light); stroke-width:1.1; }
	.brand span { display:grid; line-height:1; } .brand b { font-weight:500; letter-spacing:.2em; font-size:.9rem; } .brand small { margin-top:.45rem; color:var(--gold-light); font:400 .48rem var(--sans); letter-spacing:.32em; }
	.site-nav { display:flex; gap:clamp(1rem,2.3vw,2.3rem); } .site-nav a { position:relative; text-decoration:none; font-size:.8rem; letter-spacing:.16em; }
	.site-nav a::after { content:''; position:absolute; left:0; right:100%; bottom:-9px; height:1px; background:var(--gold-light); transition:right .25s; } .site-nav a:hover::after,.site-nav a:focus-visible::after { right:0; }
	.menu-toggle { display:none; background:none; border:0; color:inherit; }
	.hero { position:relative; min-height:100svh; overflow:hidden; color:#f4f1e9; background:radial-gradient(circle at 74% 35%, #29445a 0, #13283c 25%, #08131f 63%); }
	.hero::after { content:''; position:absolute; inset:0; pointer-events:none; background:linear-gradient(90deg,rgba(8,19,31,.55),transparent 56%),linear-gradient(0deg,rgba(8,19,31,.8),transparent 25%); }
	.hero-stars { position:absolute; inset:0; opacity:.42; background-image:radial-gradient(circle,#fff 0 1px,transparent 1.4px),radial-gradient(circle,#d9c99d 0 1px,transparent 1.4px); background-position:0 0, 47px 63px; background-size:113px 107px,151px 139px; mask-image:linear-gradient(to right,transparent,black 30%); }
	.hero-orbit { position:absolute; z-index:1; border:1px solid rgba(218,197,140,.18); border-radius:50%; transform:rotate(-18deg); }
	.orbit-one { width:730px; height:360px; right:-120px; top:26%; } .orbit-two { width:930px; height:520px; right:-190px; top:14%; }
	.hero-celestials { position:absolute; z-index:2; inset:0; overflow:hidden; pointer-events:none; }
	.hero-celestial { --celestial-entry:.2s; --celestial-float-start:1.15s; --celestial-duration:6s; position:absolute; display:block; animation:celestial-enter .9s calc(var(--hero-entry-delay) + var(--celestial-entry)) cubic-bezier(.16,.78,.18,1) both,celestial-float var(--celestial-duration) calc(var(--hero-entry-delay) + var(--celestial-float-start)) ease-in-out infinite; }
	.celestial-star { background:linear-gradient(145deg,#fff8db,#cdb16e); clip-path:polygon(50% 0,58% 42%,100% 50%,58% 58%,50% 100%,42% 58%,0 50%,42% 42%); filter:drop-shadow(0 0 12px rgba(232,211,151,.5)); }
	.celestial-star-one { --celestial-entry:.12s; --celestial-float-start:1.05s; --celestial-duration:5.6s; --celestial-opacity:.78; --celestial-drift-x:7px; --celestial-drift-y:-16px; width:34px; height:34px; left:10%; top:27%; }
	.celestial-star-two { --celestial-entry:1.02s; --celestial-float-start:1.9s; --celestial-duration:7.3s; --celestial-opacity:.58; --celestial-drift-x:-8px; --celestial-drift-y:12px; width:21px; height:21px; left:35%; bottom:17%; }
	.celestial-orb { border:1px solid rgba(229,219,187,.58); border-radius:50%; background:radial-gradient(circle at 34% 30%,#f7edcf 0 8%,#8ca9bb 24%,#29465d 68%,#12283a 100%); box-shadow:0 0 22px rgba(146,183,204,.2); }
	.celestial-orb-one { --celestial-entry:.52s; --celestial-float-start:1.35s; --celestial-duration:8.2s; --celestial-opacity:.68; --celestial-drift-x:-5px; --celestial-drift-y:-14px; width:48px; height:48px; left:42%; top:15%; }
	.celestial-orb-two { --celestial-entry:1.2s; --celestial-float-start:2s; --celestial-duration:6.8s; --celestial-opacity:.46; --celestial-drift-x:9px; --celestial-drift-y:-9px; width:25px; height:25px; right:14%; bottom:25%; }
	.celestial-moon { --celestial-entry:.72s; --celestial-float-start:1.6s; --celestial-duration:7.6s; --celestial-opacity:.62; --celestial-drift-x:8px; --celestial-drift-y:12px; width:62px; height:62px; right:34%; top:20%; border-radius:50%; background:#e8d9aa; box-shadow:inset -17px -5px 0 0 #244158,0 0 24px rgba(232,217,170,.2); }
	.celestial-ring { --celestial-entry:.34s; --celestial-float-start:1.3s; --celestial-duration:9s; --celestial-opacity:.48; --celestial-drift-x:-10px; --celestial-drift-y:9px; --celestial-tilt:-20deg; width:105px; height:42px; right:7%; top:16%; border:1px solid rgba(222,208,168,.52); border-radius:50%; box-shadow:0 0 18px rgba(222,208,168,.08); }
	.celestial-ring::after { content:''; position:absolute; width:9px; height:9px; right:11px; top:3px; border-radius:50%; background:#e4cf95; box-shadow:0 0 10px rgba(228,207,149,.55); }
	.hero-content { position:relative; z-index:4; width:var(--container); margin:auto; padding-top:24vh; }
	.hero-kicker { margin:0 0 2rem; color:var(--gold-light); font:400 .68rem var(--sans); letter-spacing:.28em; text-transform:uppercase; animation:hero-copy-in .7s var(--hero-entry-delay) cubic-bezier(.2,.75,.2,1) both; }
	.hero h1 { margin:0; width:max-content; display:grid; font-weight:400; line-height:.88; letter-spacing:.12em; animation:hero-title-in .95s calc(var(--hero-entry-delay) + .18s) cubic-bezier(.16,.78,.18,1) both; }
	.hero h1 span { font-size:clamp(3.6rem,8.2vw,8rem); text-shadow:0 10px 40px #07121f; }
	.hero h1 em { margin-top:1.3rem; margin-left:3.2em; color:var(--gold-light); font-size:clamp(1.3rem,2.6vw,2.6rem); font-style:normal; font-weight:400; letter-spacing:.45em; }
