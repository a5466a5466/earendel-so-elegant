---
import { getCollection, render, type CollectionEntry } from 'astro:content';
import LabLayout from '../../../layouts/LabLayout.astro';
import LabPageHero from '../../../components/lab/LabPageHero.astro';

export async function getStaticPaths() {
	const events = await getCollection('events');

	return events.map((event) => ({
		params: { slug: event.data.slug },
		props: { event },
	}));
}

interface Props {
	event: CollectionEntry<'events'>;
}

const { event } = Astro.props;
const { Content } = await render(event);
const allEvents = await getCollection('events');
const relatedEvents = allEvents
	.filter((candidate) => candidate.id !== event.id)
	.filter((candidate) => candidate.data.tags.some((tag) => event.data.tags.includes(tag)))
	.slice(0, 2);

const formatDate = new Intl.DateTimeFormat('zh-Hant-TW', {
	year: 'numeric',
	month: 'long',
	day: 'numeric',
});
---

<LabLayout
	title={`${event.data.title}｜活動資料 Prototype`}
	description={event.data.summary}
>
	<LabPageHero
		eyebrow={`Phase 1 · Step 1 · ${event.data.theme}`}
		title={event.data.title}
		description={event.data.summary}
		actions={[
			{ label: '返回活動列表', href: '/lab/events/' },
			{ label: '查看資料摘要', href: '#event-data' },
		]}
		headingId="event-detail-title"
	/>

	<article class="event-detail-main">
		<figure class="event-detail-cover">
			<img src={event.data.cover} alt={event.data.coverAlt} width="1200" height="800" />
			<figcaption>Step 1 placeholder・圖片最佳化留待 Step 2</figcaption>
		</figure>

		<section id="event-data" class="event-data-panel" aria-labelledby="event-data-title">
			<div>
				<p class="lab-eyebrow">Validated Frontmatter</p>
				<h2 id="event-data-title">資料摘要</h2>
			</div>
			<dl>
				<div><dt>日期</dt><dd><time datetime={event.data.date.toISOString().slice(0, 10)}>{formatDate.format(event.data.date)}</time></dd></div>
				<div><dt>Slug</dt><dd><code>{event.data.slug}</code></dd></div>
				<div><dt>Gallery</dt><dd>{event.data.gallery.length} 筆</dd></div>
				<div><dt>影片</dt><dd>{event.data.videos.length} 筆</dd></div>
				<div><dt>音訊</dt><dd>{event.data.audio.length} 筆</dd></div>
				<div><dt>社群連結</dt><dd>{event.data.socialPosts.length} 筆</dd></div>
			</dl>
		</section>

		<div class="event-detail-layout">
			<section class="event-prose" aria-labelledby="event-content-title">
				<p class="lab-eyebrow">Markdown Body</p>
				<h2 id="event-content-title">活動內容</h2>
				<Content />
			</section>

			<aside class="event-sidebar" aria-label="活動補充資料">
				<section>
					<h2>標籤</h2>
					<ul class="event-tags">
						{event.data.tags.map((tag) => <li>{tag}</li>)}
					</ul>
				</section>

				<section>
					<h2>素材署名</h2>
					<ul class="event-credit-list">
						{event.data.credits.map((credit) => (
							<li>{credit.url ? <a href={credit.url}>{credit.name}</a> : credit.name}</li>
						))}
					</ul>
				</section>

				{event.data.socialPosts.length > 0 && (
					<section>
						<h2>外部連結</h2>
						<ul class="event-link-list">
							{event.data.socialPosts.map((post) => (
								<li><a href={post.url} rel="noreferrer">{post.label}</a></li>
							))}
						</ul>
					</section>
				)}
			</aside>
		</div>

		{relatedEvents.length > 0 && (
			<nav class="event-related" aria-labelledby="related-events-title">
				<p class="lab-eyebrow">Related by Tags</p>
				<h2 id="related-events-title">相同標籤的活動</h2>
				<ul>
					{relatedEvents.map((related) => (
						<li><a href={`/lab/events/${related.data.slug}/`}>{related.data.title}</a></li>
					))}
				</ul>
			</nav>
		)}
	</article>
</LabLayout>
