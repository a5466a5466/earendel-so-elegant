---
import LabLayout from '../../layouts/LabLayout.astro';
import { nextExperiment, phaseZeroSteps } from '../../data/lab/catalog';

const homeUrl = `${import.meta.env.BASE_URL.replace(/\/$/, '')}/`;
---

<LabLayout
	title="功能實驗室｜厄倫蒂兒好氣質"
	description="厄倫蒂兒好氣質網站的 Astro 功能研究與體驗驗證空間。"
>
	<section class="lab-hero" aria-labelledby="lab-title">
		<div class="lab-stars" aria-hidden="true"></div>
		<div class="lab-orbit" aria-hidden="true"></div>
		<div class="lab-hero-inner">
			<p class="lab-kicker">Astro Function Laboratory</p>
			<h1 id="lab-title">功能<span>實驗室</span></h1>
			<p class="lab-lead">
				在功能進入正式網站以前，先在這裡驗證它的體驗、效能與維護成本。
			</p>
			<div class="lab-notice" role="note">
				<span aria-hidden="true">✦</span>
				<div>
					<strong>實驗功能</strong>
					<p>這裡包含仍在測試中的介面，結果通過驗收後才會整合回正式網站。</p>
				</div>
			</div>
		</div>
	</section>

	<section class="lab-section" aria-labelledby="foundation-title">
		<div class="lab-section-heading">
			<div>
				<p class="lab-eyebrow">Phase 0 · Foundation</p>
				<h2 id="foundation-title">建立可靠的實驗基礎</h2>
			</div>
			<p>實驗索引、共用控制器、公開保護與 QA 基線皆已完成；後續功能沿用同一套契約逐項驗證。</p>
		</div>

		<ol class="foundation-grid">
			{phaseZeroSteps.map((item) => (
				<li class={`foundation-card is-${item.state}`}>
					<div class="card-meta">
						<span>{item.step}</span>
						<small>{item.status}</small>
					</div>
					<h3>{item.title}</h3>
					<p>{item.description}</p>
					{item.href && <a class="foundation-link" href={item.href}>{item.linkLabel ?? '查看內容'} <span aria-hidden="true">→</span></a>}
				</li>
			))}
		</ol>
	</section>

	<section class="lab-section lab-roadmap" aria-labelledby="roadmap-title">
		<div>
			<p class="lab-eyebrow">Phase 3 · Current Step</p>
			<h2 id="roadmap-title">{nextExperiment.title}</h2>
			<p>{nextExperiment.description}</p>
			{'href' in nextExperiment && nextExperiment.href && (
				<a class="roadmap-link" href={nextExperiment.href}>{nextExperiment.linkLabel} <span aria-hidden="true">→</span></a>
			)}
		</div>
		<span class="roadmap-mark" aria-hidden="true">{nextExperiment.id}</span>
	</section>

	<div class="lab-home-link">
		<a href={homeUrl}>← 返回厄倫蒂兒好氣質首頁</a>
	</div>
</LabLayout>
